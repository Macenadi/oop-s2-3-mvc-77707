@model Global_College.mvc.Models.ViewModel.FacultyProfileEditViewModel

@{
    ViewData["Title"] = "Edit Faculty";
}

<h1>Edit</h1>
<h4>Faculty Profile</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="FullName" class="control-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Email" class="control-label">Personal Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Phone" class="control-label">Phone</label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="BranchId" class="control-label"></label>
                <select asp-for="BranchId" asp-items="Model.BranchOptions" class="form-control" id="BranchId">
                    <option value="">-- Select Branch --</option>
                </select>
                <span asp-validation-for="BranchId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Courses</label>

                <div class="mb-2">
                    <select id="availableCourses" class="form-control">
                        <option value="">-- Select course to add --</option>
                        @foreach (var item in Model.BranchCourseOptions)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                </div>

                <button type="button" class="btn btn-success btn-sm mb-3" id="addCourseBtn">Add Course</button>

                <div id="selectedCoursesContainer">
                    @foreach (var courseId in Model.SelectedBranchCourseIds)
                    {
                        var selectedCourse = Model.BranchCourseOptions.FirstOrDefault(x => x.Value == courseId.ToString());
                        if (selectedCourse != null)
                        {
                            <div class="card mb-2 p-2 selected-course-item" data-id="@selectedCourse.Value">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>@selectedCourse.Text</span>
                                    <button type="button" class="btn btn-danger btn-sm remove-course-btn">Delete</button>
                                </div>
                                <input type="hidden" name="SelectedBranchCourseIds" value="@selectedCourse.Value" />
                            </div>
                        }
                    }
                </div>

                <span asp-validation-for="SelectedBranchCourseIds" class="text-danger"></span>
            </div>

            <div class="form-group mb-3" id="justificationBox" style="display:none;">
                <label asp-for="ChangeJustification" class="control-label">Justification</label>
                <textarea asp-for="ChangeJustification" class="form-control" rows="4"
                          placeholder="Explain why you added, removed, or changed the course(s)."></textarea>
                <span asp-validation-for="ChangeJustification" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById("BranchId").addEventListener("change", function () {
            const branchId = this.value;
            const courseSelect = document.getElementById("SelectedBranchCourseIds");

            courseSelect.innerHTML = "";

            if (branchId) {
                fetch('/FacultyProfiles/GetCoursesByBranch?branchId=' + branchId)
                    .then(response => response.json())
                    .then(data => {
                        data.forEach(course => {
                            const option = document.createElement("option");
                            option.value = course.id;
                            option.text = course.name;
                            courseSelect.appendChild(option);
                        });
                    });
            }
        });
    </script>

    <script>
        function showJustificationBox() {
            document.getElementById("justificationBox").style.display = "block";
        }

                window.addEventListener("load", function () {
            const justification = document.getElementById("ChangeJustification");
            if (justification && justification.value.trim() !== "") {
                showJustificationBox();
            }

            const validationMessage = document.querySelector('[data-valmsg-for="ChangeJustification"]');
            if (validationMessage && validationMessage.textContent.trim() !== "") {
                showJustificationBox();
            }
        });

        document.getElementById("addCourseBtn").addEventListener("click", function () {
            const select = document.getElementById("availableCourses");
            const selectedValue = select.value;
            const selectedText = select.options[select.selectedIndex].text;
            const container = document.getElementById("selectedCoursesContainer");

            if (!selectedValue) return;

            const alreadyExists = container.querySelector('[data-id="' + selectedValue + '"]');
            if (alreadyExists) return;

            const card = document.createElement("div");
            card.className = "card mb-2 p-2 selected-course-item";
            card.setAttribute("data-id", selectedValue);

            card.innerHTML = `
                <div class="d-flex justify-content-between align-items-center">
                    <span>${selectedText}</span>
                    <button type="button" class="btn btn-danger btn-sm remove-course-btn">Delete</button>
                </div>
                <input type="hidden" name="SelectedBranchCourseIds" value="${selectedValue}" />
            `;

            container.appendChild(card);
            showJustificationBox();
        });

        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("remove-course-btn")) {
                e.target.closest(".selected-course-item").remove();
                showJustificationBox();
            }
        });
    </script>
}