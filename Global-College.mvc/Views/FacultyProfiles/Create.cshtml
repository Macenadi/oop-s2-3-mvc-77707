@model Global_College.mvc.Models.ViewModel.FacultyProfileCreateViewModel

@{
    ViewData["Title"] = "Create Faculty";
    var branchOptions = ViewBag.BranchOptions as List<SelectListItem>;
}

<h1>Create Faculty</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="FullName" class="control-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="BranchId" class="control-label">Select Branch</label>
                <select asp-for="BranchId" id="BranchId" asp-items="branchOptions" class="form-control">
                    <option value="">-- Select Branch --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SelectedBranchCourseIds" class="control-label">Available Courses</label>
                <select asp-for="SelectedBranchCourseIds" id="SelectedBranchCourseIds" class="form-control" multiple size="8"></select>
                <span asp-validation-for="SelectedBranchCourseIds" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-primary">Save Profile</button>
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $("#BranchId").change(function () {
                var branchId = $(this).val();
                var courseSelect = $("#SelectedBranchCourseIds");
                courseSelect.empty();

                if (branchId) {
                    $.getJSON('@Url.Action("GetCoursesByBranch")', { branchId: branchId }, function (data) {
                        $.each(data, function (i, item) {
                            courseSelect.append($('<option>', { value: item.id, text: item.name }));
                        });
                    });
                }
            });
        });
    </script>
}