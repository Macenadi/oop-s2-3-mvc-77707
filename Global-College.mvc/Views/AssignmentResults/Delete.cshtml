@model Global_College.domain.Models.Faculty.AssignmentResult

@{
    ViewData["Title"] = "Delete Assignment Result";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>AssignmentResult</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Score
        </dt>
        <dd class="col-sm-10">
            @Model.Score
        </dd>

        <dt class="col-sm-2">
            Grade
        </dt>
        <dd class="col-sm-10">
            @(Model.Grade + "%")
        </dd>

        <dt class="col-sm-2">
            Feedback
        </dt>
        <dd class="col-sm-10">
            @Model.Feedback
        </dd>

        <dt class="col-sm-2">
            Student
        </dt>
        <dd class="col-sm-10">
            @Model.StudentProfile?.FullName
        </dd>

        <dt class="col-sm-2">
            Assignment
        </dt>
        <dd class="col-sm-10">
            @Model.Assignment?.Title
        </dd>

        <dt class="col-sm-2">
            Class Code
        </dt>
        <dd class="col-sm-10">
            @Model.Assignment?.BranchCourse?.ClassCode
        </dd>

        <dt class="col-sm-2">
            Course
        </dt>
        <dd class="col-sm-10">
            @Model.Assignment?.BranchCourse?.Course?.Name
        </dd>

        <dt class="col-sm-2">
            Branch
        </dt>
        <dd class="col-sm-10">
            @Model.Assignment?.BranchCourse?.Branch?.Name
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index" asp-route-assignmentId="@Model.AssignmentId">Back to List</a>
    </form>
</div>