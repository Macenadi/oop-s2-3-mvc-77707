@model Global_College.mvc.ViewModels.AttendanceIndexViewModel

@{
    ViewData["Title"] = "Attendance Records";
}

<h1>Attendance Records</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<form asp-action="Index" method="get" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <label asp-for="BranchId" class="form-label">Branch</label>
            <select asp-for="BranchId" asp-items="Model.Branches" class="form-control" onchange="this.form.submit()">
                <option value="">-- Select Branch --</option>
            </select>
            <span asp-validation-for="BranchId" class="text-danger"></span>
        </div>

        <div class="col-md-5">
            <label asp-for="BranchCourseId" class="form-label">Class / Group</label>
            <select asp-for="BranchCourseId" asp-items="Model.BranchCourses" class="form-control">
                <option value="">-- Select Class / Group --</option>
            </select>
            <span asp-validation-for="BranchCourseId" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Date" class="form-label">Date</label>
            <input asp-for="Date" type="date" class="form-control" max="@DateTime.Today.ToString("yyyy-MM-dd")" />            <span asp-validation-for="Date" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Load Students</button>
    </div>

    <div class="mb-4">
        <a asp-controller="FacultyPortal" asp-action="MyClasses" class="btn btn-outline-primary me-2 mb-2">My Classes</a>
    </div>

</form>

@if (Model.Students != null && Model.Students.Any())
{
    <form asp-action="SaveAttendance" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="BranchId" />
        <input type="hidden" asp-for="BranchCourseId" />
        <input type="hidden" asp-for="Date" />

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Student Number</th>
                    <th>Full Name</th>
                    <th>Present</th>
                    <th>Change Justification</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Students.Count; i++)
                {
                    <tr>
                        <td>
                            @Model.Students[i].StudentNumber
                            <input type="hidden" asp-for="Students[i].CourseEnrolmentId" />
                            <input type="hidden" asp-for="Students[i].StudentProfileId" />
                            <input type="hidden" asp-for="Students[i].StudentNumber" />
                            <input type="hidden" asp-for="Students[i].FullName" />
                            <input type="hidden" asp-for="Students[i].AttendanceRecordId" />
                        </td>
                        <td>
                            @Model.Students[i].FullName
                        </td>
                        <td>
                            <input asp-for="Students[i].Present" class="form-check-input" />
                        </td>
                        <td>
                            <input asp-for="Students[i].ChangeJustification" class="form-control" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <button type="submit" class="btn btn-success">Save Attendance</button>
    </form>
}
else if (Model.BranchId.HasValue && Model.BranchCourseId.HasValue)
{
    <div class="alert alert-warning">
        No enrolled students found for the selected class/group.
    </div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}