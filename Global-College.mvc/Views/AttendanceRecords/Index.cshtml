@model Global_College.mvc.ViewModels.AttendanceIndexViewModel

@{
    ViewData["Title"] = "Attendance Records";
}

<h1>Attendance Records</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<form asp-action="Index" method="get" class="mb-4">
    <div class="row">
        <div class="col-md-3">
            <label asp-for="BranchId" class="form-label">Branch</label>
            <select asp-for="BranchId" asp-items="Model.Branches" class="form-select">
                <option value="">-- Select Branch --</option>
            </select>
            <span asp-validation-for="BranchId" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="CourseId" class="form-label">Course</label>
            <select asp-for="CourseId" asp-items="Model.Courses" class="form-select">
                <option value="">-- Select Course --</option>
            </select>
            <span asp-validation-for="CourseId" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Date" class="form-label">Date</label>
            <input asp-for="Date" type="date" class="form-control" />
            <span asp-validation-for="Date" class="text-danger"></span>
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Load Students</button>
        </div>
    </div>
</form>

@if (Model.Students != null && Model.Students.Any())
{
    <form asp-action="SaveAttendance" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="BranchId" />
        <input type="hidden" asp-for="CourseId" />
        <input type="hidden" asp-for="Date" />

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Student Number</th>
                    <th>Full Name</th>
                    <th>Present</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Students.Count; i++)
                {
                    <tr>
                        <td>
                            @Model.Students[i].StudentNumber
                            <input type="hidden" asp-for="Students[i].CourseEnrolmentId" />
                            <input type="hidden" asp-for="Students[i].StudentProfileId" />
                            <input type="hidden" asp-for="Students[i].StudentNumber" />
                            <input type="hidden" asp-for="Students[i].FullName" />
                            <input type="hidden" asp-for="Students[i].AttendanceRecordId" />
                        </td>
                        <td>
                            @Model.Students[i].FullName
                        </td>
                        <td>
                            <input asp-for="Students[i].Present" class="form-check-input" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <button type="submit" class="btn btn-success">Save Attendance</button>
    </form>
}
else if (Model.BranchId.HasValue && Model.CourseId.HasValue)
{
    <div class="alert alert-warning">
        No enrolled students found for the selected branch and course.
    </div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
