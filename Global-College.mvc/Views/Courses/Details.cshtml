@model Global_College.domain.Models.Administrator.Course

@{
    ViewData["Title"] = "Details";
    var branchStudentCounts = ViewBag.BranchStudentCounts as Dictionary<int, int>;
}

<h1>Details</h1>

<div>
    <h4>Course</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
    </dl>
</div>

<div class="mt-4">
    <h4>Related Branches</h4>
    <hr />

    @if (Model.BranchCourses != null && Model.BranchCourses.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Branch Name</th>
                    <th>Address</th>
                    <th>Enrolled Students</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var branchCourse in Model.BranchCourses)
                {
                    var studentCount = 0;

                    if (branchStudentCounts != null && branchStudentCounts.ContainsKey(branchCourse.Id))
                    {
                        studentCount = branchStudentCounts[branchCourse.Id];
                    }

                    <tr>
                        <td>@branchCourse.Branch?.Name</td>
                        <td>@branchCourse.Branch?.Address</td>
                        <td>@studentCount</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No branches are related to this course.</p>
    }
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>