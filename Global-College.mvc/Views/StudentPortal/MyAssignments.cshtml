@model Global_College.mvc.Models.ViewModel.MyAssignmentsViewModel

@{
    ViewData["Title"] = "My Assignments";
}

<h1>My Assignments</h1>

<div class="card mb-4">
    <div class="card-body">
        <h4>@Model.Header.StudentName</h4>
        <p><strong>Current Course:</strong> @Model.Header.CurrentCourseName</p>
        <p><strong>Branch:</strong> @Model.Header.CurrentBranchName</p>
        <p><strong>Class Code:</strong> @Model.Header.CurrentClassCode</p>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Title</th>
            <th>Professor</th>
            <th>Course</th>
            <th>Branch</th>
            <th>Class Code</th>
            <th>Due Date</th>
            <th>Max Score</th>
            <th>Score</th>
            <th>Grade</th>
            <th>Feedback</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.TeacherNames</td>
                <td>@item.CourseName</td>
                <td>@item.BranchName</td>
                <td>@item.ClassCode</td>
                <td>@item.DueDate.ToString("dd/MM/yyyy")</td>
                <td>@item.MaxScore</td>
                <td>@item.Score</td>
                <td>@item.Grade</td>
                <td>@item.Feedback</td>
            </tr>
        }
    </tbody>
</table>