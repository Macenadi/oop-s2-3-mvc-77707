@model Global_College.mvc.Models.ViewModel.MyExamResultsViewModel

@{
    ViewData["Title"] = "My Exam Results";
}

<h1>My Exam Results</h1>

<div class="card mb-4">
    <div class="card-body">
        <h4 class="mb-3">@Model.Header.StudentName</h4>

        <div class="row">
            <div class="col-md-4">
                <strong>Student Number:</strong><br />
                @Model.Header.StudentNumber
            </div>

            <div class="col-md-4">
                <strong>Current Course:</strong><br />
                @Model.Header.CurrentCourseName
            </div>

            <div class="col-md-4">
                <strong>Branch:</strong><br />
                @Model.Header.CurrentBranchName
            </div>
        </div>

        <div class="mt-3">
            <strong>Class Code:</strong>
            @Model.Header.CurrentClassCode
        </div>
    </div>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">
        No released exam results available.
    </div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Exam</th>
                <th>Professor</th>
                <th>Class Code</th>
                <th>Course</th>
                <th>Branch</th>
                <th>Date</th>
                <th>Max Score</th>
                <th>Score</th>
                <th>Grade (%)</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.TeacherNames</td>
                    <td>@item.ClassCode</td>
                    <td>@item.CourseName</td>
                    <td>@item.BranchName</td>
                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                    <td>@item.MaxScore</td>
                    <td>@item.Score</td>
                    <td>@item.Grade</td>
                </tr>
            }
        </tbody>
    </table>
}