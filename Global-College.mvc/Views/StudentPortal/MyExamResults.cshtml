@model IEnumerable<Global_College.domain.Models.Student.ExamResult>

@{
    ViewData["Title"] = "My Exam Results";
}

<h1>My Exam Results</h1>

<table class="table">
    <thead>
        <tr>
            <th>Exam</th>
            <th>Course</th>
            <th>Score</th>
            <th>Grade</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Exam!.Title</td>
                <td>@item.Exam!.Course!.Name</td>
                <td>@item.Score</td>
                <td>@item.Grade</td>
            </tr>
        }
    </tbody>
</table>