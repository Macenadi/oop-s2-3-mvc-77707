@model Global_College.domain.Models.Student.ExamResult

@{
    ViewData["Title"] = "Delete Exam Result";
}

<h1>Delete Exam Result</h1>

<h3>Are you sure you want to delete this result?</h3>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Exam</dt>
            <dd class="col-sm-9">@Model.Exam?.Title</dd>

            <dt class="col-sm-3">Class Code</dt>
            <dd class="col-sm-9">@Model.Exam?.BranchCourse?.ClassCode</dd>

            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.Exam?.BranchCourse?.Course?.Name</dd>

            <dt class="col-sm-3">Branch</dt>
            <dd class="col-sm-9">@Model.Exam?.BranchCourse?.Branch?.Name</dd>

            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9">@Model.StudentProfile?.FullName</dd>

            <dt class="col-sm-3">Score</dt>
            <dd class="col-sm-9">@Model.Score</dd>

            <dt class="col-sm-3">Grade</dt>
            <dd class="col-sm-9">@Model.Grade</dd>

            <dt class="col-sm-3">Release Status</dt>
            <dd class="col-sm-9">
                @if (Model.Exam?.ResultsReleased == true)
                {
                    <span class="badge bg-success">Released</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Provisional</span>
                }
            </dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="Index" asp-route-examId="@Model.ExamId" class="btn btn-secondary">Back to List</a>
        </form>
    </div>
</div>