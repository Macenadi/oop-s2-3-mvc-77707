@model IEnumerable<Global_College.domain.Models.Student.ExamResult>

@{
    ViewData["Title"] = "Exam Results";
}

<h1>Exam Results</h1>

@if (ViewBag.SelectedExamTitle != null)
{
    <div class="alert alert-info">
        Results for: <strong>@ViewBag.SelectedExamTitle</strong> - @ViewBag.SelectedClassCode
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<div class="mb-4">
    <a asp-controller="FacultyPortal" asp-action="MyClasses" class="btn btn-outline-primary me-2 mb-2">My Classes</a>
</div>


<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Exam</th>
            <th>Class Code</th>
            <th>Course</th>
            <th>Branch</th>
            <th>Student</th>
            <th>Score</th>
            <th>Max Score</th>
            <th>Grade</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Exam?.Title</td>
                <td>@item.Exam?.BranchCourse?.ClassCode</td>
                <td>@item.Exam?.BranchCourse?.Course?.Name</td>
                <td>@item.Exam?.BranchCourse?.Branch?.Name</td>
                <td>@item.StudentProfile?.FullName</td>
                <td>@item.Score</td>
                <td>@item.Exam?.MaxScore</td>
                <td>@item.Grade</td>
                <td>
                    @if (item.Exam?.ResultsReleased == true)
                    {
                        <span class="badge bg-success">Released</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Provisional</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>