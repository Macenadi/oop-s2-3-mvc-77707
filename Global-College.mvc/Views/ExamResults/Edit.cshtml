@model Global_College.domain.Models.Student.ExamResult

@{
    ViewData["Title"] = "Edit Exam Result";
}

<h1>Edit Exam Result</h1>

<h4>Exam Result</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="ExamId" class="control-label">Exam</label>
                <select asp-for="ExamId" class="form-control" asp-items="ViewBag.ExamId"></select>
                <span asp-validation-for="ExamId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="StudentProfileId" class="control-label">Student</label>
                <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.StudentProfileId"></select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Score" class="control-label"></label>
                <input asp-for="Score" class="form-control" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Grade</label>
                <input class="form-control" value="@Model.Grade" readonly />
                <small class="text-muted">Grade is calculated automatically from Score.</small>
            </div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" asp-route-examId="@Model.ExamId" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}