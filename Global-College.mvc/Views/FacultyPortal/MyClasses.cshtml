@model Global_College.mvc.Models.ViewModel.FacultyMyClassesViewModel

@{
    ViewData["Title"] = "My Classes";
}

<h1>My Classes</h1>

<div class="card mb-4">
    <div class="card-body">
        <h4>@Model.Header.FacultyName</h4>
        <p><strong>Faculty Number:</strong> @Model.Header.FacultyNumber</p>
        <p><strong>System Email:</strong> @Model.Header.SystemEmail</p>
        <p><strong>Assigned Classes:</strong> @Model.Header.AssignedClassesCount</p>
    </div>
</div>

<div class="mb-4">
    <a asp-controller="FacultyPortal" asp-action="MyClasses" class="btn btn-primary me-2 mb-2">My Classes</a>
    <a asp-controller="FacultyPortal" asp-action="MyAssignments" class="btn btn-outline-primary me-2 mb-2">My Assignments</a>
    <a asp-controller="FacultyPortal" asp-action="MyAttendance" class="btn btn-outline-primary me-2 mb-2">My Attendance</a>
    <a asp-controller="FacultyPortal" asp-action="MyExamResults" class="btn btn-outline-primary me-2 mb-2">My Exam Results</a>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">
        No assigned classes found.
    </div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Course</th>
                <th>Branch</th>
                <th>Class Code</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.CourseName</td>
                    <td>@item.BranchName</td>
                    <td>@item.ClassCode</td>
                    <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                    <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        <a asp-controller="Assignments" asp-action="Index" class="btn btn-sm btn-outline-primary mb-1">Assignments</a>
                        <a asp-controller="AttendanceRecords" asp-action="Index" asp-route-branchCourseId="@item.BranchCourseId" class="btn btn-sm btn-outline-success mb-1">Attendance</a>
                        <a asp-controller="Exams" asp-action="Index" class="btn btn-sm btn-outline-warning mb-1">Exams</a>
                        <a asp-controller="ExamResults" asp-action="Index" class="btn btn-sm btn-outline-info mb-1">Exam Results</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}