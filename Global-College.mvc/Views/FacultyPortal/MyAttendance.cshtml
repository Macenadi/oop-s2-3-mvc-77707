@model Global_College.mvc.Models.ViewModel.FacultyMyAttendanceViewModel

@{
    ViewData["Title"] = "My Attendance";
}

<h1>My Attendance</h1>

<div class="card mb-4">
    <div class="card-body">
        <h4>@Model.Header.FacultyName</h4>
        <p><strong>Faculty Number:</strong> @Model.Header.FacultyNumber</p>
        <p><strong>System Email:</strong> @Model.Header.SystemEmail</p>
        <p><strong>Assigned Classes:</strong> @Model.Header.AssignedClassesCount</p>
    </div>
</div>

<div class="mb-4">
    <a asp-controller="FacultyPortal" asp-action="MyClasses" class="btn btn-outline-primary me-2 mb-2">My Classes</a>
    <a asp-controller="FacultyPortal" asp-action="MyAssignments" class="btn btn-outline-primary me-2 mb-2">My Assignments</a>
    <a asp-controller="FacultyPortal" asp-action="MyAttendance" class="btn btn-primary me-2 mb-2">My Attendance</a>
    <a asp-controller="FacultyPortal" asp-action="MyExamResults" class="btn btn-outline-primary me-2 mb-2">My Exam Results</a>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">
        No attendance records found.
    </div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Date</th>
                <th>Student</th>
                <th>Student Number</th>
                <th>Course</th>
                <th>Branch</th>
                <th>Class Code</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                    <td>@item.StudentName</td>
                    <td>@item.StudentNumber</td>
                    <td>@item.CourseName</td>
                    <td>@item.BranchName</td>
                    <td>@item.ClassCode</td>
                    <td>
                        @if (item.Present)
                        {
                            <span class="text-success">Present</span>
                        }
                        else
                        {
                            <span class="text-danger">Absent</span>
                        }
                    </td>
                    <td>
                        <a asp-controller="AttendanceRecords" asp-action="Details" asp-route-id="@item.AttendanceRecordId" class="btn btn-sm btn-outline-info">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}