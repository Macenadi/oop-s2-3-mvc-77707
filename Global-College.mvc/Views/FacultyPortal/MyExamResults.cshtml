@model Global_College.mvc.Models.ViewModel.FacultyMyExamResultsViewModel

@{
    ViewData["Title"] = "My Exam Results";
}

<h1>My Exam Results</h1>

<div class="card mb-4">
    <div class="card-body">
        <h4>@Model.Header.FacultyName</h4>
        <p><strong>Faculty Number:</strong> @Model.Header.FacultyNumber</p>
        <p><strong>System Email:</strong> @Model.Header.SystemEmail</p>
        <p><strong>Assigned Classes:</strong> @Model.Header.AssignedClassesCount</p>
    </div>
</div>

<div class="mb-4">
    <a asp-controller="FacultyPortal" asp-action="MyClasses" class="btn btn-outline-primary me-2 mb-2">My Classes</a>
    <a asp-controller="FacultyPortal" asp-action="MyAssignments" class="btn btn-outline-primary me-2 mb-2">My Assignments</a>
    <a asp-controller="FacultyPortal" asp-action="MyAttendance" class="btn btn-outline-primary me-2 mb-2">My Attendance</a>
    <a asp-controller="FacultyPortal" asp-action="MyExamResults" class="btn btn-primary me-2 mb-2">My Exam Results</a>
</div>

<div class="mb-3">
    <a asp-controller="ExamResults" asp-action="Create" class="btn btn-success">Create Exam Result</a>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">
        No exam results found.
    </div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Exam</th>
                <th>Student</th>
                <th>Student Number</th>
                <th>Course</th>
                <th>Branch</th>
                <th>Class Code</th>
                <th>Date</th>
                <th>Score</th>
                <th>Grade</th>
                <th>Released</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.ExamTitle</td>
                    <td>@item.StudentName</td>
                    <td>@item.StudentNumber</td>
                    <td>@item.CourseName</td>
                    <td>@item.BranchName</td>
                    <td>@item.ClassCode</td>
                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                    <td>@item.Score</td>
                    <td>@item.Grade</td>
                    <td>
                        @if (item.ResultsReleased)
                        {
                            <span class="badge bg-success">Released</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Provisional</span>
                        }
                    </td>
                    <td>
                        <a asp-controller="ExamResults" asp-action="Details" asp-route-id="@item.ExamResultId" class="btn btn-sm btn-outline-info mb-1">Details</a>
                        <a asp-controller="ExamResults" asp-action="Edit" asp-route-id="@item.ExamResultId" class="btn btn-sm btn-outline-warning mb-1">Edit</a>
                        <a asp-controller="ExamResults" asp-action="Delete" asp-route-id="@item.ExamResultId" class="btn btn-sm btn-outline-danger mb-1">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}