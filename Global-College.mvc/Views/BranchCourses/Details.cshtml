@model Global_College.domain.Models.Administrator.BranchCourse

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>BranchCourse</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Branch
        </dt>
        <dd class="col-sm-10">
            @Model.Branch?.Name - @Model.Branch?.Address
        </dd>

        <dt class="col-sm-2">
            Course
        </dt>
        <dd class="col-sm-10">
            @Model.Course?.Name
        </dd>

        <dt class="col-sm-2">
            Class Code
        </dt>
        <dd class="col-sm-10">
            @Model.ClassCode
        </dd>

        <dt class="col-sm-2">
            Start Date
        </dt>
        <dd class="col-sm-10">
            @Model.StartDate.ToString("dd/MM/yyyy")
        </dd>

        <dt class="col-sm-2">
            End Date
        </dt>
        <dd class="col-sm-10">
            @Model.EndDate.ToString("dd/MM/yyyy")
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
