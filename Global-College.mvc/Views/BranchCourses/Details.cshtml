@model Global_College.mvc.Models.ViewModel.BranchCourseDetailsViewModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>BranchCourse</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Branch
        </dt>
        <dd class="col-sm-10">
            @Model.BranchCourse.Branch?.Name - @Model.BranchCourse.Branch?.Address
        </dd>

        <dt class="col-sm-2">
            Course
        </dt>
        <dd class="col-sm-10">
            @Model.BranchCourse.Course?.Name
        </dd>

        <dt class="col-sm-2">
            Class Code
        </dt>
        <dd class="col-sm-10">
            @Model.BranchCourse.ClassCode
        </dd>

        <dt class="col-sm-2">
            Start Date
        </dt>
        <dd class="col-sm-10">
            @Model.BranchCourse.StartDate.ToString("dd/MM/yyyy")
        </dd>

        <dt class="col-sm-2">
            End Date
        </dt>
        <dd class="col-sm-10">
            @Model.BranchCourse.EndDate.ToString("dd/MM/yyyy")
        </dd>
    </dl>
</div>

<!-- 🔹 ADIÇÃO MÍNIMA -->
<div class="mt-4">
    <h4>Courses Linked to this Branch</h4>
    <hr />

    @if (Model.RelatedBranchCourses != null && Model.RelatedBranchCourses.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Course Name</th>
                    <th>Class Code</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Enrolled</th>
                    <th>Finished</th>
                    <th>Dropped</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.RelatedBranchCourses)
                {
                    <tr>
                        <td>@item.Course?.Name</td>
                        <td>@item.ClassCode</td>
                        <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.CourseEnrolments.Count(e => e.Status == "Enrolled")</td>
                        <td>@item.CourseEnrolments.Count(e => e.Status == "Finished")</td>
                        <td>@item.CourseEnrolments.Count(e => e.Status == "Dropped")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No courses are linked to this branch.</p>
    }
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.BranchCourse.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>