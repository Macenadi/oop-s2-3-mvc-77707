@model Global_College.domain.Models.Administrator.Branch

@{
    ViewData["Title"] = "Delete";
    bool canDelete = ViewBag.CanDelete != null && (bool)ViewBag.CanDelete;
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>

<div>
    <h4>Branch</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Branch Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Address</dt>
        <dd class="col-sm-10">@Model.Address</dd>
    </dl>

    @if (!canDelete)
    {
        <div class="alert alert-warning">
            This branch cannot be deleted because it is linked to one or more branch courses.
        </div>
    }

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />

        @if (canDelete)
        {
            <input type="submit" value="Delete" class="btn btn-danger" />
        }
        else
        {
            <input type="button" value="Delete" class="btn btn-danger" disabled />
        }

        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
