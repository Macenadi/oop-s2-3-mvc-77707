@model Global_College.domain.Models.Administrator.CourseEnrolment

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Course Enrolment</h4>
    <hr />

    <h5>Student Information</h5>
    <dl class="row">
        <dt class="col-sm-2">Full Name</dt>
        <dd class="col-sm-10">@Model.StudentProfile!.FullName</dd>

        <dt class="col-sm-2">Student Number</dt>
        <dd class="col-sm-10">@Model.StudentProfile.StudentNumber</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.StudentProfile.Email</dd>

        <dt class="col-sm-2">Phone</dt>
        <dd class="col-sm-10">@Model.StudentProfile.Phone</dd>
    </dl>

    <h5>Course Information</h5>
    <dl class="row">
        <dt class="col-sm-2">Branch</dt>
        <dd class="col-sm-10">@Model.BranchCourse!.Branch!.Name</dd>

        <dt class="col-sm-2">Course</dt>
        <dd class="col-sm-10">@Model.BranchCourse.Course!.Name</dd>

        <dt class="col-sm-2">Class Code</dt>
        <dd class="col-sm-10">@Model.BranchCourse.ClassCode</dd>
    </dl>

    <h5>Enrolment Information</h5>
    <dl class="row">
        <dt class="col-sm-2">Enrol Date</dt>
        <dd class="col-sm-10">@Model.EnrolDate</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>

        <dt class="col-sm-2">Justification</dt>
        <dd class="col-sm-10">
            @(string.IsNullOrWhiteSpace(Model.Justification) ? "-" : Model.Justification)
        </dd>

        @if (Model.StoppedDate.HasValue)
        {
            <dt class="col-sm-2">Stopped Date</dt>
            <dd class="col-sm-10">@Model.StoppedDate</dd>
        }
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>