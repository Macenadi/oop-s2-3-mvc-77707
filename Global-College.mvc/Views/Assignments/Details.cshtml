@model Global_College.domain.Models.Faculty.Assignment

@{
    ViewData["Title"] = "Assignment Details";
}

<h1>Assignment Details</h1>

<div class="card shadow-sm">
    <div class="card-header">
        <h4 class="mb-0">@Model.Title</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">Max Score</dt>
            <dd class="col-sm-9">@Model.MaxScore</dd>

            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">@Model.DueDate</dd>

            <dt class="col-sm-3">Class Code</dt>
            <dd class="col-sm-9">@Model.BranchCourse?.ClassCode</dd>

            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.BranchCourse?.Course?.Name</dd>

            <dt class="col-sm-3">Branch</dt>
            <dd class="col-sm-9">@Model.BranchCourse?.Branch?.Name</dd>

            <dt class="col-sm-3">Class Start Date</dt>
            <dd class="col-sm-9">@Model.BranchCourse?.StartDate</dd>

            <dt class="col-sm-3">Class End Date</dt>
            <dd class="col-sm-9">@Model.BranchCourse?.EndDate</dd>
        </dl>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Students in Class</h5>
                <p class="fs-4 mb-0">@ViewBag.TotalStudentsInClass</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Results Entered</h5>
                <p class="fs-4 mb-0">@ViewBag.TotalResults</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Pending Results</h5>
                <p class="fs-4 mb-0">@ViewBag.PendingResults</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit</a>
    <a asp-controller="AssignmentResults" asp-action="Create" asp-route-assignmentId="@Model.Id" class="btn btn-success">Add Result</a>
    <a asp-controller="AssignmentResults" asp-action="Index" asp-route-assignmentId="@Model.Id" class="btn btn-info">View Results</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>