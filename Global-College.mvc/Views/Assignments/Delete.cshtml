@model Global_College.domain.Models.Faculty.Assignment

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Assignment</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.MaxScore)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.MaxScore)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DueDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DueDate)
        </dd>

        <dt class="col-sm-2">
            Class Code
        </dt>
        <dd class="col-sm-10">
            @Model.BranchCourse?.ClassCode
        </dd>

        <dt class="col-sm-2">
            Course
        </dt>
        <dd class="col-sm-10">
            @Model.BranchCourse?.Course?.Name
        </dd>

        <dt class="col-sm-2">
            Branch
        </dt>
        <dd class="col-sm-10">
            @Model.BranchCourse?.Branch?.Name
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>