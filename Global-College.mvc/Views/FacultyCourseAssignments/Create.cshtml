@model Global_College.mvc.Models.ViewModel.FacultyProfileCreateViewModel

@{
    ViewData["Title"] = "Create";
    var branchOptions = ViewBag.BranchOptions as List<SelectListItem>;
    var branchCourseOptions = ViewBag.BranchCourseOptions as List<SelectListItem>;
}

<h1>Create</h1>

<h4>Faculty Profile</h4>
<hr />

<div class="row">
    <div class="col-md-7">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="FullName" class="control-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Phone" class="control-label"></label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="BranchId" class="control-label"></label>
                <select asp-for="BranchId" asp-items="branchOptions" class="form-control"></select>
                <span asp-validation-for="BranchId" class="text-danger"></span>
            </div>

            <div class="alert alert-info">
                Select one city/branch first. The faculty member may teach more than one course, but all courses must be in the same city.
            </div>

            <div class="form-group mb-3">
                <label asp-for="SelectedBranchCourseIds" class="control-label"></label>
                <select asp-for="SelectedBranchCourseIds" asp-items="branchCourseOptions" class="form-control" multiple size="8"></select>
                <span asp-validation-for="SelectedBranchCourseIds" class="text-danger"></span>
            </div>

            <div class="alert alert-info">
                Personal Email = professor's real email.
                System Email and System Password will be created automatically.
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}