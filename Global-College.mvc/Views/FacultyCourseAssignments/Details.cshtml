@model Global_College.domain.Models.Administrator.FacultyCourseAssignment

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Faculty Course Assignment</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Full Name</dt>
        <dd class="col-sm-10">@Model.FacultyProfile?.FullName</dd>

        <dt class="col-sm-2">Personal Email</dt>
        <dd class="col-sm-10">@Model.FacultyProfile?.Email</dd>

        <dt class="col-sm-2">Phone</dt>
        <dd class="col-sm-10">@Model.FacultyProfile?.Phone</dd>

        <dt class="col-sm-2">Identity User ID</dt>
        <dd class="col-sm-10">@Model.FacultyProfile?.IdentityUserId</dd>

        <dt class="col-sm-2">System Email</dt>
        <dd class="col-sm-10">@Model.FacultyProfile?.SystemEmail</dd>

        <dt class="col-sm-2">System Password</dt>
        <dd class="col-sm-10">@Model.FacultyProfile?.SystemPassword</dd>
    </dl>
</div>

<div class="mt-4">
    <h4>Assigned Course</h4>
    <hr />

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>City / Branch</th>
                <th>Course</th>
                <th>Created At</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>@Model.BranchCourse?.Branch?.Name</td>
                <td>@Model.BranchCourse?.Course?.Name</td>
                <td>@Model.BranchCourse?.Course?.CreatedAt.ToString("dd/MM/yyyy")</td>
            </tr>
        </tbody>
    </table>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>